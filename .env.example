# === OBRIGATÓRIO ===
GROQ_API_KEY=gsk_sua_chave_aqui
TELEGRAM_TOKEN=seu_token_do_bot_aqui

# === GOOGLE (opcional, mas recomendado) ===
# Crie um OAuth Client ID em https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","project_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_secret":"...","redirect_uris":["http://localhost"]}}
# Após autenticar pela primeira vez, o token será gerado automaticamente.
# Para produção (Render), configure GOOGLE_TOKEN_JSON manualmente.
# GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...",...}

# === OPCIONAL ===
DATABASE_URL=
# Se vazio, usa SQLite. Se postgres://..., usa PostgreSQL.
# No Render, configure como: postgresql://user:pass@host:5432/koda

OCR_SPACE_API_KEY=
# Se vazio, OCR via Groq (LLaVA) será usado como fallback interno

# === AMBIENTE ===
ENVIRONMENT=development
PORT=5000
